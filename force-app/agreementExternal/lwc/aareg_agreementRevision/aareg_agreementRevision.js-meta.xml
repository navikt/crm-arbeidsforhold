<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Arbeidsforhold - loggført aktivitet på revisjon</masterLabel>
    <description>Viser Task-records av angitt type (default: Revisjon) for parent record.</description>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property
                name="cardTitle"
                type="String"
                label="Tittel på kort"
                default="Loggført aktivitet under revisjon" />
            <property
                name="taskType"
                type="String"
                label="Task Type"
                default="Revisjon"
                description="Verdien fra Type-feltet på Task som skal filtreres på." />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>